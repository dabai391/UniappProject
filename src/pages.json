{
  "easycom": {
    "autoscan": true,
    "custom": {
      // uni-ui 规则如下配置
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue",
      // 自定义组件规则如下配置
      "^Xtx(.*)": "@/components/Xtx$1.vue"
    }
  },
  "pages": [
    //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
    {
      "path": "pages/home/home",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/cate/cate",
      "style": {
        "navigationBarTitleText": "商品分类",
        "navigationBarBackgroundColor": "#fff",
        "navigationBarTextStyle": "black"
      }
    },
    {
      "path": "pages/cart/cart",
      "style": { "navigationBarTitleText": "购物车" ,"navigationBarBackgroundColor":"#fff"}
    },
    {
      "path": "pages/my/my",
      "style": { "navigationBarTitleText": "我的" ,"navigationStyle":"custom","navigationBarTextStyle": "white"}
    },
    {
      "path": "pages/hot/hot",
      "style": { "navigationBarBackgroundColor": "#fff", "navigationBarTextStyle": "black" }
    },
    {
      "path": "pages/cate/components/GoodsDetail",
      "style": {
        "navigationBarTitleText": "商品详情",
        "navigationBarBackgroundColor": "#fff",
        "navigationBarTextStyle": "black"
      }
    },
    {
      "path": "pages/my/components/Login",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationBarBackgroundColor": "#fff",
        "navigationBarTextStyle": "black"
      }
    }
  ],
  //分包加载规则
  "subPackages": [
    {
      "root": "pagesMember",
      "pages": [
       {
        "path": "settings/Setting",
        "style": {
          "navigationBarTitleText": "设置",
          "navigationBarBackgroundColor": "#fff",
          "navigationBarTextStyle": "black"
        }
       },
       {
        "path": "userinfo/UserInfo",
        "style": {
          "navigationStyle": "custom",
          "navigationBarBackgroundColor": "#fff"
        }
       },
       {
        "path": "address/Address",
        "style": {
          "navigationBarTitleText": "地址管理",
          "navigationBarBackgroundColor": "#fff",
          "navigationBarTextStyle": "black"
        }
       },
       {
        "path": "address/EditAdress",
        "style": {
          "navigationBarBackgroundColor": "#fff",
          "navigationBarTextStyle": "black"
        }
       }
      ]
    }

  ],
  // 分包预下载规则
	"preloadRule": {
		"pages/my/my": {
			"network": "all",
			"packages": [
				"pagesMember"
			]
		}
	},
  "globalStyle": {
    // 导航栏文字颜色全局配置
    // 下拉刷新背景颜色全局配置
    "backgroundColor": "#F8F8F8",
    "backgroundTextStyle": "light"
  },
  "tabBar": {
    "color": "#000",
    "selectedColor": "#27ba9b",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/home/home",
        "text": "首页",
        "iconPath": "static/tabs/home_default.png",
        "selectedIconPath": "static/tabs/home_selected.png"
      },
      {
        "pagePath": "pages/cate/cate",
        "text": "分类",
        "iconPath": "static/tabs/category_default.png",
        "selectedIconPath": "static/tabs/category_selected.png"
      },
      {
        "pagePath": "pages/cart/cart",
        "text": "购物车",
        "iconPath": "static/tabs/cart_default.png",
        "selectedIconPath": "static/tabs/cart_selected.png"
      },
      {
        "pagePath": "pages/my/my",
        "text": "我的",
        "iconPath": "static/tabs/user_default.png",
        "selectedIconPath": "static/tabs/user_selected.png"
      }
    ]
  }
}
